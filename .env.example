# Copy this file to .env and fill in real values. Never commit the real .env file.

GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash

# Phase 4 (optional) — swap the planner backend from the hosted Gemini API to
# a cheaper locally-hosted fine-tuned model for routine steps. Leave as
# "hosted" unless you have a local model server running; safety behavior
# (risk classification, confirmation gate) is unaffected either way.
PLANNER_BACKEND=hosted
LOCAL_PLANNER_ENDPOINT=

DEFAULT_CHROME_PROFILE=Default
# PROFILES_DIR must be the actual Chrome "User Data" ROOT folder — e.g.
# C:\Users\<you>\AppData\Local\Google\Chrome\User Data — NOT a
# Pixel-only/profile-specific folder. DEFAULT_CHROME_PROFILE must be the real
# on-disk profile folder name (e.g. "Profile 3", "Default"), found via
# chrome://version -> "Profile Path" while that profile is active in Chrome —
# NOT the friendly display name shown in Chrome's profile picker (those are
# separate labels; "Yash" the display name might live in "Profile 3" on
# disk). Fully close Chrome before running Pixel — a real running Chrome on
# the same profile blocks Playwright from launching against it.
PROFILES_DIR=C:\Users\<you>\AppData\Local\Google\Chrome\User Data

MAX_STEPS_PER_TASK=40

LOG_DIR=./logs

# Optional — only needed once Langfuse observability is wired in (docs/CODE_LOGIC.md §14)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
