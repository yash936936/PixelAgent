# Copy this file to .env and fill in real values. Never commit the real .env file.

GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.5-flash

# Phase 4 (optional) — swap the planner backend from the hosted Gemini API to
# a cheaper locally-hosted fine-tuned model for routine steps. Leave as
# "hosted" unless you have a local model server running; safety behavior
# (risk classification, confirmation gate) is unaffected either way.
PLANNER_BACKEND=hosted
LOCAL_PLANNER_ENDPOINT=

DEFAULT_CHROME_PROFILE=Default
PROFILES_DIR=./profiles

MAX_STEPS_PER_TASK=40

LOG_DIR=./logs

# Optional — only needed once Langfuse observability is wired in (docs/CODE_LOGIC.md §14)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
